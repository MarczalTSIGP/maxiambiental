<% provide(:head_title, t('devise.sessions.sign_up')) %>

<%= simple_form_for @client, url: client_registration_path, html: { class: "space-y-4 md:space-y-6" } do |f| %>
   <%= f.input :email %>
   <%= f.input :password %>
   <%= f.input :password_confirmation %>

   <%= f.button :submit, t('devise.sessions.sign_up') %>

   <%= render 'clients/devise/shared/google_auth' %>

   <%= render 'clients/devise/shared/links', action: 'sign_in' %>
<% end %>