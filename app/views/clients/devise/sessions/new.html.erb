<% provide(:head_title, t('devise.sessions.sign_in')) %>

<%= simple_form_for @client, url: client_session_path, html: { class: "space-y-4 md:space-y-6" }  do |f| %>

   <%= f.input :email %>
   <%= f.input :password %>

   <div class="flex items-center justify-between">
      <%= f.input :remember_me, label: t('simple_form.labels.remember_me'), wrapper: :tailwind_checkbox,as: :boolean if devise_mapping.rememberable? %>
      <%= link_to 'Esqueceu sua senha?', new_client_password_path, class: "font-semibold text-green-600 hover:text-green-500" %>
   </div>

   <%= f.button :submit, t('devise.sessions.sign_in') %>

   <%= render 'clients/devise/sessions/google_auth' %>

   <%= render 'clients/devise/shared/links', path: 'new_client_registration_path' %>
<% end %>
