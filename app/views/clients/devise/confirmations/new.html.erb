<%= simple_form_for @client, url: client_confirmation_path, html: { class: "space-y-4 md:space-y-6" } do |f| %>
   <%= f.error_notification %>
   <%= f.full_error :confirmation_token %>

   <%= f.input :email, value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email) %>

   <%= f.button :submit, "Reenviar Confirmação" %>
<% end %>