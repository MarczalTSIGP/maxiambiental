<% provide(:head_title, 'Novo link de redefinição') %>

<%= simple_form_for @client, url: client_confirmation_path, html: { class: "space-y-4 md:space-y-6" } do |f| %>
   <%= f.input :email, value: (@client.pending_reconfirmation? ? @client.unconfirmed_email : @client.email) %>
   <%=f.button :submit, "Reenvie-me o link de redefinição" %>
<% end %>
